# Optional: --env-file .env.agent-gateway with:
#   docker compose -f docker-compose.yml -f docker-compose.agent.yml up -d
# Or put GATEWAY_* in the root .env

GATEWAY_FLOW2API_BEARER=replace-with-long-random-secret
GATEWAY_AGENT_DEVICE_TOKEN=replace-with-another-secret-for-pc-agents
GATEWAY_AGENT_AUTH_MODE=legacy
# keygen|dual modes:
# KEYGEN_VERIFY_MODE=jwt
# KEYGEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# KEYGEN_API_TOKEN=
# KEYGEN_API_URL=https://api.keygen.sh
# KEYGEN_ISSUER=https://api.keygen.sh
# KEYGEN_AUDIENCE=flow2api-agent-gateway
# AGENT_TOKEN_OWNERSHIP_JSON={"machine-1":[1,2],"license-abc":[3]}
SOLVE_TIMEOUT_SECONDS=120
